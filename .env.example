# zyra-ws — environment variables
# Copy to .env and fill in the values.

# HTTP port for the WebSocket server (default: 3004)
PORT=3004

# MUST match zyra-api's tokenKey — used to validate JWT access tokens
tokenKey=change-me-in-production

# Comma-separated list of allowed WebSocket origins.
# Use "*" for local development. List explicit origins in production.
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
